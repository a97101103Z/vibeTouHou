# Set default behavior to automatically normalize line endings
* text=auto

# Force LF for files that will run in Linux/Docker
*.py text eol=lf
*.sh text eol=lf
Dockerfile* text eol=lf
requirements.txt text eol=lf

# Keep markdown consistent
*.md text eol=lf

# Web source files — force LF so Windows editors don't cause merge conflicts
*.js text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf